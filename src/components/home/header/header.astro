---
import TypeEffect from "./typewriter.vue"
import SocialIcons from "../../socialicons/socialicons.vue"
---

<header class="relative h-screen bg-gray-950 overflow-hidden">
  <div class="absolute inset-0 grid grid-cols-2">
    <div
      class="animate-gradientMove h-80 bg-linear-to-br from-[#982cf0] to-[#581f86] opacity-30 blur-[120px]"
    >
    </div>
    <div
      class="animate-gradientMove2 h-80 bg-linear-to-br from-[#277752] to-[#02ffee] opacity-30 blur-[120px]"
    >
    </div>
  </div>

  <main
    class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4"
  >
    <h1 class="text-4xl md:text-7xl font-bold text-white text-shadow mt-10">
      Hola! Soc en Pau
    </h1>

    <TypeEffect client:visible texts={["Desenvolupador Web", "Frontend", "Backend"]}/>

    <p class="text-xs md:text-xl text-white max-w-sm md:max-w-xl font-semibold mt-3" >
      Explora els meus projectes i la meva formacio i, si t'interessa, pots contactar-me, 
      ¡soc a un unic missatge de distancia!
    </p>
     <SocialIcons client:visible />
    <a
      target="_blank"
      href="https://drive.google.com/file/d/1mssQ4UAqKSV5bZLk6ry4Rq07TD5FFzDV/view?usp=sharing"
      class="px-6 py-3 bg-primary hover:bg-secondary mt-3 text-white font-semibold rounded-3xl transition-all duration-150
         drop-shadow-[2px_2px_0_#0debd8] active:translate-0.5 active:drop-shadow-none"
    >
      El meu CV
    </a>
  </main>
</header>
